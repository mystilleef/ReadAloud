{
  "name": "readaloud",
  "author": "Lateef Alabi-Oki <mystilleef@gmail.com>",
  "license": "GPL-3.0-or-later",
  "version": "0.44.13",
  "type": "module",
  "repository": "https://github.com/mystilleef/ReadAloud",
  "description": "An extension to read aloud selected text in Google Chrome",
  "keywords": [
    "chrome-extension",
    "web-extension",
    "typescript",
    "read aloud"
  ],
  "scripts": {
    "clean": "rimraf dist tsconfig.tsbuildinfo",
    "migrate": "biome migrate --write",
    "precheck": "npm run migrate && npm run clean",
    "check": "biome check --write --unsafe --error-on-warnings . && tsc --noEmit",
    "prebuild": "npm run check",
    "build": "tsc -b && vite build",
    "prewatch": "npm run test",
    "watch": "vite",
    "preview": "vite preview",
    "prerelease": "npm run test",
    "release": "ts-node-esm scripts/release.ts",
    "predeploy": "npm run test",
    "deploy": "ts-node-esm scripts/deploy.ts",
    "test-auth": "ts-node-esm scripts/service-account-auth.ts",
    "pretest": "npm run build",
    "test": "vitest run",
    "precoverage": "npm run build",
    "coverage": "vitest run --coverage",
    "verify": "npm run test"
  },
  "dependencies": {
    "@extend-chrome/messages": "^1.2.2",
    "@extend-chrome/storage": "^1.5.0",
    "rxjs": "^7.8.2"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.1",
    "@crxjs/vite-plugin": "^2.7.0",
    "@types/chrome": "^0.2.0",
    "@types/node": "^26.0.1",
    "@types/web": "^0.0.350",
    "chalk": "^5.6.2",
    "chrome-webstore-upload": "^6.0.0",
    "eslint": "^10.6.0",
    "execa": "^9.6.1",
    "google-auth-library": "^10.9.0",
    "rimraf": "^6.1.3",
    "rollup": "^4.62.2",
    "rollup-plugin-zip": "^1.0.3",
    "semver": "^7.8.5",
    "ts-node": "^10.9.2",
    "tslib": "^2.8.1",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vite-plugin-biome": "^1.2.0",
    "vite-plugin-static-copy": "^4.1.1",
    "vite-plugin-zip-pack": "^1.2.4",
    "@vitest/coverage-v8": "^4.1.9",
    "@types/jsdom": "^28.0.3",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "vite-plugin-biome": {
      "@biomejs/biome": "$@biomejs/biome"
    },
    "@crxjs/vite-plugin": {
      "rollup": "2.80.0"
    }
  }
}
